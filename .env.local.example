# ===== Orbita — variables de entorno =====
# Copia este archivo a .env.local y rellena los valores.
# La app corre COMPLETA solo con ANTHROPIC_API_KEY. El resto es opcional.

# --- OBLIGATORIO: el cerebro orquestador ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OPCIONAL: persistencia con Supabase ---
# Si no las pones, Orbita usa un store en memoria (el estado se pierde al reiniciar el server).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxx

# --- OPCIONAL: tools externas (si no están, se usan STUBS) ---
# OpenAI Images para generate_image
# OPENAI_API_KEY=sk-xxxxxxxx
# Modelo de imagen (deja el id exacto del ultimo, "image 2.0"). Por defecto gpt-image-1.
# OPENAI_IMAGE_MODEL=gpt-image-1

# Kling para generate_video (API asíncrona; define también su endpoint)
# KLING_API_KEY=xxxxxxxx
# KLING_API_URL=https://api.klingai.com/v1/videos/text2video

# Búsqueda web real para web_search (si no, resultados simulados)
# TAVILY_API_KEY=tvly-xxxxxxxx

# --- VOZ (UGC Studio) ---
# ElevenLabs: mejor prosodia/emoción. Con la key puesta es el provider por
# defecto; si falla en runtime cae solo a Gemini TTS.
# OJO licencia: el free tier NO permite uso comercial (ads) — plan Starter o superior.
# ELEVENLABS_API_KEY=sk_xxxxxxxx
# Voz por defecto (si la persona no tiene elevenVoiceId propio). Default: Adam.
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Modelo: eleven_multilingual_v2 (default) | eleven_v3 (tags de emoción [laughs], [sighs])
# ELEVENLABS_MODEL=eleven_multilingual_v2
# Forzar provider sin quitar keys: elevenlabs | gemini
# VOICE_PROVIDER=elevenlabs

# Gemini TTS (fallback / voz nombrada por persona)
# GEMINI_API_KEY=AIzaxxxxxxxx
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# --- VIDEO (Seedance 2.0 vía fal) ---
# FAL_KEY=xxxxxxxx:xxxxxxxx
# SEEDANCE_MODEL=bytedance/seedance-2.0/reference-to-video
# SEEDANCE_RESOLUTION=720p
# SEEDANCE_DURATION=8
# Presupuesto default por producción del UGC Studio (USD)
# UGC_DEFAULT_BUDGET_USD=10
